#!/usr/bin/env bash
set -ue -o pipefail
# vim:ft=bash:
# fco - checkout git branch/tag

fco() {
	local tags branches target
	branches=$(git --no-pager branch --all \
		--format="%(if)%(HEAD)%(then)%(else)%(if:equals=HEAD)%(refname:strip=3)%(then)%(else)%1B[0;34;1mbranch%09%1B[m%(refname:short)%(end)%(end)" |
		sed '/^$/d') || return
	tags=$(git --no-pager tag | awk '{print "\x1b[35;1mtag\x1b[m\t" $1}') || return
	target=$(
		(
			echo "$branches"
			echo "$tags"
		) |
			fzf --no-hscroll --reverse --no-multi -n 2 \
				--ansi --preview="git --no-pager log -150 --oneline '..{2}'"
	) || return
	git checkout "$(awk '{print $2}' <<<"$target")"
}

fco "$@"
</file>

<file path="zsh/bin/fgd">
#!/usr/bin/env bash
set -ue -o pipefail
# fgd - delete git branch/tag

fgd() {
	local tags branches target
	tags=$(
		git tag | awk '{print "\x1b[31;1mtag\x1b[m\t" $1}'
	) || return
	branches=$(
		git branch --all | grep -v HEAD |
			sed "s/.* //" | sed "s#remotes/[^/]*/##" |
			sort -u | awk '{print "\x1b[34;1mbranch\x1b[m\t" $1}'
	) || return
	target=$(
		(
			echo "$tags"
			echo "$branches"
		) |
			fzf --reverse --no-hscroll --ansi +m -d "\t" -n 2
	) || return

	if [ "$(echo "$target" | awk '{print $1}')" = "tag" ]; then
		echo "$(echo "$target" | awk '{print $2}')"
		git tag -d "$(echo "$target" | awk '{print $2}')"
	fi

	if [ "$(echo "$target" | awk '{print $1}')" = "branch" ]; then
		echo "$(echo "$target" | awk '{print $2}')"
		git branch -D "$(echo "$target" | awk '{print $2}')"
	fi
}

fgd "$@"
</file>

