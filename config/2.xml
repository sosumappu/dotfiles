# This file is for when I CMD+click a file inside kitty

# Open file links in the closest Neovim pane inside tmux.
# Fragments are generated by the hyperlink_grep kitten and may include line/column data.
protocol file
fragment_matches .*[0-9].*
action launch --type=background --copy-env --cwd=current --allow-remote-control ${HOME}/.config/zsh/bin/kitty-open-in-nvim @active-kitty-window-id ${URL}

# Open file links that encode line/column data in the path itself.
protocol file
url .+:[0-9]+(:[0-9]+)?$
action launch --type=background --copy-env --cwd=current --allow-remote-control ${HOME}/.config/zsh/bin/kitty-open-in-nvim @active-kitty-window-id ${URL}

# Tail a log file (*.log) in a new OS Window and reduce its font size
protocol file
ext log
action launch --title ${FILE} --type=os-window tail -f ${FILE_PATH}
action change_font_size current -2

# Open text files without fragments in the closest Neovim pane inside tmux.
protocol file
mime text/*
action launch --type=background --copy-env --cwd=current --allow-remote-control ${HOME}/.config/zsh/bin/kitty-open-in-nvim @active-kitty-window-id ${URL}

# Open any image in the full kitty window by clicking on it
protocol file
mime image/*
action launch --type=overlay kitty +kitten icat --hold ${FILE_PATH}

protocol filelist
action send_text all ${FRAGMENT}
