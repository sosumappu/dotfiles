#!/usr/bin/env sh
set -ue -o pipefail
# Usage: git-edit [conflicted|staged|edited|committed]

case ${1-} in
conflict | conflicts | conflicted)
	$EDITOR $(git-conflicts)
	;;
committed)
	$EDITOR $(git diff HEAD^ --name-only --diff-filter=ACMR)
	;;
staged)
