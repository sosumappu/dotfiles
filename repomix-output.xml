<file path="ntfy.nix">
let
  module = {
    pkgs,
    lib,
    config,
    ...
  }: let
    cfg = config.my.modules.ntfy;
  in {
    options = with lib; {
      my.modules.ntfy = {
        port = mkOption {
          type = types.port;
          default = 2586;
        };

        baseUrl = mkOption {
          type = types.str;
          description = "Public base URL — must match what clients connect to";
          example = "https://ntfy.home.example.com";
        };

        dataDir = mkOption {
          type = types.str;
          default = "/var/lib/ntfy-sh";
        };

        cacheDuration = mkOption {
          type = types.str;
          default = "24h";
          description = "How long messages are cached (allows offline clients to catch up)";
        };

        # agenix-managed env file at /etc/secrets/ntfy.conf
        # You can set any ntfy config key as an env var here, prefixed with NTFY_.
        # Minimum useful content:
        #   NTFY_AUTH_DEFAULT_ACCESS=deny-all
        #
        # Add users after first start:
        #   ntfy user add --role=admin alice
        #   ntfy token add alice
        secretsFile = mkOption {
          type = types.str;
          default = "/etc/secrets/ntfy.conf";
        };

        # Default access when no user ACL matches.
        # 'deny-all' is the right default for a homelab — add users explicitly.
        authDefaultAccess = mkOption {
          type = types.enum ["read-write" "read-only" "write-only" "deny-all"];
          default = "deny-all";
        };
      };
    };

    config = with lib; {
      services.ntfy-sh = {
        enable = true;
        settings = {
          listen-http = ":${toString cfg.port}";
          base-url = cfg.baseUrl;

          cache-file = "${cfg.dataDir}/cache.db";
          cache-duration = cfg.cacheDuration;

          attachment-cache-dir = "${cfg.dataDir}/attachments";
          attachment-expiry-duration = "3h";
          attachment-total-size-limit = "2G";
          attachment-file-size-limit = "15M";

          auth-file = "${cfg.dataDir}/user.db";
          auth-default-access = cfg.authDefaultAccess;

          # Keep connections alive so mobile clients don't miss messages
          keepalive-interval = "45s";

          visitor-message-daily-limit = 500;
          visitor-subscription-limit = 50;
          global-topic-limit = 100;
        };
      };

      systemd.services.ntfy-sh.serviceConfig.EnvironmentFile = cfg.secretsFile;

      systemd.tmpfiles.rules = [
        "d ${cfg.dataDir}             0750 ntfy-sh ntfy-sh -"
        "d ${cfg.dataDir}/attachments 0750 ntfy-sh ntfy-sh -"
      ];

      # Small helper available system-wide, handy in restic hooks or any script:
      #
      #   notify-homelab homelab-alerts "Backup failed" "restic exited non-zero" --priority high
      #   notify-homelab homelab-info   "Backup done"   "home: 1.2 GB in 42s"
      #
      # The topic must already exist / be accessible with the token in secretsFile.
      # Set NTFY_TOKEN in your shell or pass --header "Authorization: Bearer $token" manually.
      environment.systemPackages = [
        (pkgs.writeShellScriptBin "notify-homelab" ''
          set -euo pipefail
          TOPIC="''${1:?Usage: notify-homelab <topic> <title> <message> [extra-curl-flags...]}"
          TITLE="''${2:?missing title}"
          MESSAGE="''${3:?missing message}"
          shift 3

          # Token is sourced from the environment — set NTFY_TOKEN in the
          # calling service's EnvironmentFile or export it in your shell.
          AUTH_HEADER=""
          if [ -n "''${NTFY_TOKEN:-}" ]; then
            AUTH_HEADER="Authorization: Bearer $NTFY_TOKEN"
          fi

          ${pkgs.curl}/bin/curl -s \
            --url "${cfg.baseUrl}/$TOPIC" \
            ${lib.optionalString true ''--header "Title: $TITLE"''} \
            ''${AUTH_HEADER:+--header "$AUTH_HEADER"} \
            --data "$MESSAGE" \
            "$@"
        '')
      ];
    };
  };
in {
  flake.modules.nixos.ntfy = module;
}
</file>

<file path="prometheus.nix">
let
  module = {
    pkgs,
    lib,
    config,
    ...
  }: let
    cfg = config.my.modules.prometheus;
  in {
    options = with lib; {
      my.modules.prometheus = {
        port = mkOption {
          type = types.port;
          default = 9090;
        };

        retentionTime = mkOption {
          type = types.str;
          default = "30d";
          example = "90d";
        };

        exporters = {
          node = {
            port = mkOption {
              type = types.port;
              default = 9100;
            };
            enabledCollectors = mkOption {
              type = types.listOf types.str;
              default = [
                "cpu"
                "diskstats"
                "filesystem"
                "loadavg"
                "meminfo"
                "netdev"
                "netstat"
                "os"
                "stat"
                "systemd"
                "time"
                "uname"
              ];
            };
            disabledCollectors = mkOption {
              type = types.listOf types.str;
              default = ["ipvs" "zfs" "infiniband"];
            };
          };

          systemd = {
            port = mkOption {
              type = types.port;
              default = 9558;
            };
            # Narrow this per-host by overriding in your host config,
            # e.g. my.modules.prometheus.exporters.systemd.unitWhitelist =
            #   "(vaultwarden|immich|syncthing).+\\.service";
            unitWhitelist = mkOption {
              type = types.str;
              default = ".+\\.service";
            };
          };

          process = {
            port = mkOption {
              type = types.port;
              default = 9256;
            };
            # Add/remove groups per-host by overriding this in your host config.
            groups = mkOption {
              type = types.listOf (types.submodule {
                options = {
                  name = mkOption {type = types.str;};
                  cmdlineMatchers = mkOption {
                    type = types.listOf types.str;
                    default = [];
                    description = "Substrings matched against /proc/<pid>/cmdline";
                  };
                  commMatchers = mkOption {
                    type = types.listOf types.str;
                    default = [];
                    description = "Exact names matched against /proc/<pid>/comm";
                  };
                };
              });
              default = [
                {
                  name = "immich";
                  cmdlineMatchers = ["immich" "node /usr/src/app"];
                }
                {
                  name = "vaultwarden";
                  commMatchers = ["vaultwarden"];
                }
                {
                  name = "syncthing";
                  commMatchers = ["syncthing"];
                }
                {
                  name = "adguardhome";
                  commMatchers = ["AdGuardHome"];
                }
              ];
            };
          };
        };

        # Extra scrape jobs beyond the local exporters — point at other hosts.
        extraScrapeConfigs = mkOption {
          type = types.listOf types.attrs;
          default = [];
          example = [
            {
              job_name = "berry-node";
              static_configs = [{targets = ["berry:9100"];}];
            }
          ];
        };

        alertmanager = {
          port = mkOption {
            type = types.port;
            default = 9093;
          };

          # agenix-managed file at /etc/secrets/alertmanager.conf
          # Must be a valid alertmanager YAML config — receiver tokens/passwords
          # (ntfy, smtp) live here, never in the Nix store.
          secretsFile = mkOption {
            type = types.str;
            default = "/etc/secrets/alertmanager.conf";
          };

          # Append extra rule groups on top of the built-in homelab defaults.
          extraRules = mkOption {
            type = types.listOf types.attrs;
            default = [];
          };
        };
      };
    };

    config = with lib; let
      processExporterConfig = pkgs.writeText "process-exporter.yaml" (
        builtins.toJSON {
          process_names =
            map (g: {
              name = "{{.Matches}}";
              cmdline = g.cmdlineMatchers;
              comm = g.commMatchers;
            })
            cfg.exporters.process.groups;
        }
      );

      defaultRules = [
        {
          name = "homelab.node";
          rules = [
            {
              alert = "HostHighCpuLoad";
              expr = ''100 - (avg by(instance) (rate(node_cpu_seconds_total{mode="idle"}[5m])) * 100) > 80'';
              for = "10m";
              labels.severity = "warning";
              annotations.summary = "High CPU on {{ $labels.instance }} ({{ printf \"%.0f\" $value }}%)";
            }
            {
              alert = "HostLowDisk";
              expr = ''(node_filesystem_avail_bytes{mountpoint="/"} / node_filesystem_size_bytes{mountpoint="/"}) * 100 < 15'';
              for = "5m";
              labels.severity = "warning";
              annotations.summary = "Low disk on {{ $labels.instance }} ({{ printf \"%.0f\" $value }}% free)";
            }
            {
              alert = "HostCriticalDisk";
              expr = ''(node_filesystem_avail_bytes{mountpoint="/"} / node_filesystem_size_bytes{mountpoint="/"}) * 100 < 5'';
              for = "2m";
              labels.severity = "critical";
              annotations.summary = "Critical disk on {{ $labels.instance }} ({{ printf \"%.0f\" $value }}% free)";
            }
            {
              alert = "HostHighMemory";
              expr = "(1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)) * 100 > 90";
              for = "10m";
              labels.severity = "warning";
              annotations.summary = "High memory on {{ $labels.instance }} ({{ printf \"%.0f\" $value }}%)";
            }
          ];
        }
        {
          name = "homelab.services";
          rules = [
            {
              alert = "ServiceFailed";
              expr = ''systemd_unit_state{state="failed"} == 1'';
              for = "2m";
              labels.severity = "critical";
              annotations.summary = "{{ $labels.name }} failed on {{ $labels.instance }}";
            }
            {
              alert = "ServiceFrequentRestarts";
              expr = "rate(systemd_unit_restart_total[15m]) > 0.1";
              for = "5m";
              labels.severity = "warning";
              annotations.summary = "{{ $labels.name }} restarting frequently on {{ $labels.instance }}";
            }
          ];
        }
        {
          name = "homelab.backups";
          rules = [
            # Pair with a pushgateway push in your restic backupCleanupCommand:
            #   echo "restic_last_success_timestamp_seconds $(date +%s)" | \
            #     curl --data-binary @- http://localhost:9091/metrics/job/restic/instance/$(hostname)
            {
              alert = "BackupTooOld";
              expr = "time() - restic_last_success_timestamp_seconds > 86400 * 2";
              for = "1h";
              labels.severity = "warning";
              annotations.summary = "Backup {{ $labels.job }} hasn't run in 2 days on {{ $labels.instance }}";
            }
          ];
        }
      ];

      rulesFile = pkgs.writeText "homelab-alerts.yaml" (
        builtins.toJSON {groups = defaultRules ++ cfg.alertmanager.extraRules;}
      );

      localScrapes = [
        {
          job_name = "node";
          static_configs = [{targets = ["localhost:${toString cfg.exporters.node.port}"];}];
        }
        {
          job_name = "systemd";
          static_configs = [{targets = ["localhost:${toString cfg.exporters.systemd.port}"];}];
        }
        {
          job_name = "process";
          static_configs = [{targets = ["localhost:${toString cfg.exporters.process.port}"];}];
        }
      ];
    in {
      services.prometheus.exporters.node = {
        enable = true;
        inherit (cfg.exporters.node) port enabledCollectors disabledCollectors;
      };

      services.prometheus.exporters.systemd = {
        enable = true;
        inherit (cfg.exporters.systemd) port;
        extraFlags = ["--systemd.unit-whitelist=${cfg.exporters.systemd.unitWhitelist}"];
      };

      systemd.services.process-exporter = {
        description = "Prometheus process exporter";
        wantedBy = ["multi-user.target"];
        after = ["network.target"];
        serviceConfig = {
          ExecStart = "${pkgs.process-exporter}/bin/process-exporter --config.path=${processExporterConfig} --web.listen-address=:${toString cfg.exporters.process.port}";
          Restart = "on-failure";
          DynamicUser = true;
          ReadOnlyPaths = ["/proc"];
        };
      };

      services.prometheus = {
        enable = true;
        inherit (cfg) port retentionTime;
        ruleFiles = [rulesFile];
        scrapeConfigs = localScrapes ++ cfg.extraScrapeConfigs;
        alertmanagers = [
          {
            static_configs = [{targets = ["localhost:${toString cfg.alertmanager.port}"];}];
          }
        ];
      };

      services.prometheus.alertmanager = {
        enable = true;
        inherit (cfg.alertmanager) port;
        configFile = cfg.alertmanager.secretsFile;
      };
    };
  };
in {
  flake.modules.nixos.prometheus = module;
}
</file>

<file path="restic.nix">
let
  module = {
    pkgs,
    lib,
    config,
    ...
  }: let
    cfg = config.my.modules.restic;
    hostname = config.networking.hostName;

    resolvedBackups = lib.mapAttrs (
      _: backup:
        backup // (backup.hostOverrides.${hostname} or {})
    ) (lib.filterAttrs (_: b: b.enable) cfg.backups);
  in {
    options = with lib; {
      my.modules.restic = {
        passwordFile = mkOption {
          type = types.nullOr types.str;
          default = null;
          description = "Global repository password file, passed as RESTIC_PASSWORD_FILE";
        };

        environmentFile = mkOption {
          type = types.nullOr types.str;
          default = null;
          description = "Global environment file for backend credentials (S3, B2, etc.)";
        };

        repository = mkOption {
          type = types.nullOr types.str;
          default = null;
          description = "Global repository URL, can be overridden per backup";
          example = "s3:s3.amazonaws.com/my-bucket";
        };

        backups = mkOption {
          default = {};
          type = types.attrsOf (types.submodule ({
            name,
            config,
            ...
          }: {
            options = {
              enable = mkOption {
                type = types.bool;
                default = true;
              };

              # Repository override — falls back to cfg.repository
              repository = mkOption {
                type = types.nullOr types.str;
                default = null;
                description = "Override global repository for this backup";
              };

              repositoryFile = mkOption {
                type = types.nullOr types.path;
                default = null;
                description = "Path to file containing repository URL (alternative to repository)";
              };

              passwordFile = mkOption {
                type = types.nullOr types.str;
                default = null;
                description = "Override global passwordFile for this backup";
              };

              environmentFile = mkOption {
                type = types.nullOr types.str;
                default = null;
                description = "Override global environmentFile for this backup";
              };

              paths = mkOption {
                type = types.listOf types.str;
                default = [];
                example = ["/home" "/etc/nixos"];
              };

              exclude = mkOption {
                type = types.listOf types.str;
                default = [".cache" "*.tmp" "node_modules" ".git"];
                description = "Exclude patterns, written to an exclude file passed to restic";
              };

              dynamicFilesFrom = mkOption {
                type = types.nullOr types.str;
                default = null;
                description = "Shell script producing extra paths to back up, passed to --files-from";
                example = "find /home -name '*.org' -type f";
              };

              timerConfig = mkOption {
                type = types.nullOr (types.attrsOf types.anything);
                default = {
                  OnCalendar = "daily";
                  Persistent = true;
                };
                description = "systemd.timer config. Set to null to disable automatic scheduling";
                example = {
                  OnCalendar = "00:05";
                  RandomizedDelaySec = "5h";
                  Persistent = true;
                };
              };

              user = mkOption {
                type = types.str;
                default = "root";
                description = "User the backup service runs as";
              };

              initialize = mkOption {
                type = types.bool;
                default = true;
                description = "Run restic init if the repository does not exist yet";
              };

              pruneOpts = mkOption {
                type = types.listOf types.str;
                default = [
                  "--keep-daily 7"
                  "--keep-weekly 5"
                  "--keep-monthly 12"
                  "--keep-yearly 3"
                ];
                description = "Options passed to restic forget --prune after each backup";
              };

              checkOpts = mkOption {
                type = types.listOf types.str;
                default = [];
                description = "Options passed to restic check. Enables runCheck when non-empty";
                example = ["--with-cache"];
              };

              extraBackupArgs = mkOption {
                type = types.listOf types.str;
                default = [];
                description = "Extra arguments passed to restic backup";
                example = ["--cleanup-cache"];
              };

              extraOptions = mkOption {
                type = types.listOf types.str;
                default = [];
                description = "Extended options passed via restic --option";
              };

              backupPrepareCommand = mkOption {
                type = types.nullOr types.str;
                default = null;
                description = "Script to run before the backup starts";
              };

              backupCleanupCommand = mkOption {
                type = types.nullOr types.str;
                default = null;
                description = "Script to run after the backup finishes";
              };

              inhibitsSleep = mkOption {
                type = types.bool;
                default = false;
                description = "Prevent the system from sleeping while backing up";
              };

              hostOverrides = mkOption {
                type = types.attrsOf types.anything;
                default = {};
                description = "Per-hostname overrides, keyed by networking.hostName";
                example = {
                  my-server = {timerConfig.OnCalendar = "hourly";};
                  my-laptop = {timerConfig.OnCalendar = "daily";};
                };
              };
            };
          }));
        };
      };
    };

    config = with lib;
      mkIf (resolvedBackups != {}) {
        services.restic.backups =
          mapAttrs (_: backup: {
            repository = backup.repository or cfg.repository;
            inherit (backup) repositoryFile;
            passwordFile = backup.passwordFile or cfg.passwordFile;
            environmentFile = backup.environmentFile or cfg.environmentFile;

            inherit (backup) paths;
            inherit (backup) exclude;
            inherit (backup) dynamicFilesFrom;

            inherit (backup) initialize;
            inherit (backup) pruneOpts;
            inherit (backup) checkOpts;
            inherit (backup) extraBackupArgs;
            inherit (backup) extraOptions;
            inherit (backup) timerConfig;
            inherit (backup) user;
            inherit (backup) inhibitsSleep;

            inherit (backup) backupPrepareCommand;
            inherit (backup) backupCleanupCommand;
          })
          resolvedBackups;
      };
  };
in {
  flake.modules.nixos.restic = module;
}
</file>

<file path="vaultwarden.nix">
let
  module = {
    pkgs,
    lib,
    config,
    ...
  }: let
    cfg = config.my.modules.vaultwarden;
  in {
    options = with lib; {
      my.modules.vaultwarden = {
        port = mkOption {
          type = types.port;
          default = 8222;
        };

        websocketPort = mkOption {
          type = types.port;
          default = 3012;
        };

        domain = mkOption {
          type = types.str;
          description = "Public-facing domain (used for DOMAIN env var and invite links)";
          example = "vault.home.example.com";
        };

        dataDir = mkOption {
          type = types.str;
          default = "/var/lib/vaultwarden";
        };

        # agenix-managed env file at /etc/secrets/vaultwarden.conf
        # Required variables:
        #   ADMIN_TOKEN=<argon2-hashed-token>
        #
        # Generate with: vaultwarden hash --preset owasp
        # Optional (if smtp.enable):
        #   SMTP_PASSWORD=<password>
        secretsFile = mkOption {
          type = types.str;
          default = "/etc/secrets/vaultwarden.conf";
        };

        signupsAllowed = mkOption {
          type = types.bool;
          default = false;
          description = "Disable after initial account creation";
        };

        signupDomains = mkOption {
          type = types.listOf types.str;
          default = [];
          description = "Restrict signups to these domains when signupsAllowed = true";
        };

        invitationsAllowed = mkOption {
          type = types.bool;
          default = true;
        };

        smtp = {
          enable = mkOption {
            type = types.bool;
            default = false;
          };
          host = mkOption {
            type = types.str;
            default = "";
            example = "smtp.fastmail.com";
          };
          port = mkOption {
            type = types.port;
            default = 587;
          };
          from = mkOption {
            type = types.str;
            default = "";
            example = "vault@example.com";
          };
          username = mkOption {
            type = types.str;
            default = "";
          };
        };
      };
    };

    config = with lib; {
      services.vaultwarden = {
        enable = true;
        dbBackend = "sqlite";

        config =
          {
            DATA_FOLDER = cfg.dataDir;
            ROCKET_PORT = cfg.port;
            ROCKET_ADDRESS = "127.0.0.1";

            WEBSOCKET_ENABLED = true;
            WEBSOCKET_PORT = cfg.websocketPort;

            DOMAIN = "https://${cfg.domain}";

            SIGNUPS_ALLOWED = cfg.signupsAllowed;
            INVITATIONS_ALLOWED = cfg.invitationsAllowed;
            SIGNUPS_DOMAINS_WHITELIST = concatStringsSep "," cfg.signupDomains;

            LOG_LEVEL = "warn";
            EXTENDED_LOGGING = true;

            # Conservative rate limits for a personal instance
            LOGIN_RATELIMIT_MAX_BURST = 10;
            LOGIN_RATELIMIT_SECONDS = 60;
            ADMIN_RATELIMIT_MAX_BURST = 5;
            ADMIN_RATELIMIT_SECONDS = 300;
          }
          // optionalAttrs cfg.smtp.enable {
            SMTP_HOST = cfg.smtp.host;
            SMTP_PORT = cfg.smtp.port;
            SMTP_FROM = cfg.smtp.from;
            SMTP_USERNAME = cfg.smtp.username;
            SMTP_SECURITY = "starttls";
          };

        # ADMIN_TOKEN (and SMTP_PASSWORD if smtp enabled) live here —
        # never in the Nix store.
        environmentFile = cfg.secretsFile;
      };

      systemd.tmpfiles.rules = [
        "d ${cfg.dataDir} 0700 vaultwarden vaultwarden -"
      ];

      # Flush the SQLite WAL before any backup runs against dataDir.
      # Wire this into restic like:
      #   my.modules.restic.backups.vaultwarden.backupPrepareCommand =
      #     "systemctl start vaultwarden-wal-flush";
      systemd.services.vaultwarden-wal-flush = {
        description = "Flush Vaultwarden SQLite WAL before backup";
        serviceConfig = {
          Type = "oneshot";
          User = "vaultwarden";
          ExecStart = pkgs.writeShellScript "vaultwarden-wal-flush" ''
            set -euo pipefail
            DB="${cfg.dataDir}/db.sqlite3"
            [ -f "$DB" ] && ${pkgs.sqlite}/bin/sqlite3 "$DB" "PRAGMA wal_checkpoint(TRUNCATE);"
          '';
        };
      };
    };
  };
in {
  flake.modules.nixos.vaultwarden = module;
}
</file>

