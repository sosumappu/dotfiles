    environment.shellAliases.l = pkgs.lib.mkForce null;

    programs = {
      gnupg.agent = {pinentryPackage = pkgs.pinentry-curses;};
      less.enable = true;
      mosh.enable = true;
      npm.enable = true;
    };
  };

  systemImports = [
    (inputs.self.lib.mkFeatureModule "nixos" {
      features = [
        "system-base"
        "shell"
        "git"
        "jujutsu"
