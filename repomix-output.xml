stdenvNoCC.mkDerivation rec {
  name = "hcron";
  version = "1.1.1";
  dontBuild = true;
  dontConfigure = true;

  src = fetchurl {
    url = "https://github.com/lnquy/cron/releases/download/v${version}/cron_${version}_darwin_amd64.tar.gz";
    sha256 = "0p42691d0wy14wjbgy3rp2pcsn3xrni9fnw35wia6jrsha2w5z07";
