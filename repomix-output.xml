          default-cache-ttl 86400
          max-cache-ttl 86400'';

        "gnupg/gpg.conf".text = ''
          # ${myConfig.nix_managed}
          ${builtins.readFile ../../../../config/gnupg/gpg.conf}'';
      };
    };
  };
in {
  flake = {
    modules = {
